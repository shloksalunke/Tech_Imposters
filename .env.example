## Never commit real keys. Copy to `.env` locally.

# Binance (optional; public endpoints still work without keys)
BINANCE_API_SECRET_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# PostgreSQL Configuration (optional; app can fall back to Binance public OHLCV)
DB_HOST=localhost
DB_PORT=5432
DB_USER=binance_user
DB_PASSWORD=secure_password_123
DB_NAME=binance_data

# CryptoPanic (News)
CRYPTOPANIC_AUTH_TOKEN=your_cryptopanic_token
CRYPTOPANIC_API_URL=https://cryptopanic.com/api/v1/posts

# Crypto.news (News scraping)
CRYPTONEWS_URL=https://crypto.news/

# Etherscan (On-chain)
ETHERSCAN_API_KEY=your_etherscan_key
# Binance API Configuration
API_KEY=your_binance_api_key_here
API_SECRET=your_binance_api_secret_here

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=binance_user
DB_PASSWORD=secure_password_123
DB_NAME=binance_data

# Reddit API Configuration
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=CryptoPredictionBot/1.0
